{
  "name": "software-barbearia",
  "version": "1.0.0",
  "description": "Plataforma premium de gestao para barbearias",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run dev:pilot",
    "dev:pilot": "node scripts/start-pilot-local.mjs",
    "dev:isolated": "node scripts/start-isolated-local.mjs",
    "evolution:build": "docker compose -f infra/evolution-local/docker-compose.yml build api",
    "evolution:up": "docker compose -f infra/evolution-local/docker-compose.yml up -d --build",
    "evolution:doctor": "node scripts/evolution-doctor.mjs",
    "evolution:recover": "node scripts/evolution-recover.mjs",
    "test:evolution": "vitest run tests/evolution-local-infrastructure.spec.ts",
    "test:evolution:image": "node scripts/evolution-image-smoke.mjs",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "deploy": "npm run build && npx prisma generate && npx prisma migrate deploy",
    "canonicals:dry-run": "tsx scripts/provision-canonicals-local.ts --dry-run --target=local",
    "canonicals:apply:local": "tsx scripts/provision-canonicals-local.ts --apply --target=local",
    "macro233:cleanup:dry-run": "tsx scripts/cleanup-macro-233-local.ts --dry-run",
    "macro233:cleanup:apply:local": "tsx scripts/cleanup-macro-233-local.ts --apply",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:demo": "tsx prisma/demo-seed.ts",
    "db:reset:geovane-pilot": "node scripts/reset-geovane-pilot.mjs",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "test:db": "tsx scripts/run-db-tests.ts",
    "test:migration:2290": "tsx scripts/test-migration-2290.ts",
    "test:stability": "tsx scripts/run-local-stability.ts",
    "semantic:benchmark": "tsx scripts/benchmark-local-semantic.ts",
    "semantic:doctor": "node scripts/local-semantic-doctor.mjs",
    "smoke:api": "node scripts/smoke-api-flow.mjs",
    "smoke:api:readonly": "node scripts/smoke-api-readonly.mjs",
    "smoke:api:ps": "powershell -ExecutionPolicy Bypass -File scripts/smoke-api-flow.ps1"
  },
  "keywords": [
    "barbearia",
    "gestao",
    "saas",
    "agenda",
    "financeiro"
  ],
  "author": "Projeto Software Barbearia Premium",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "cross-env": "^10.1.0",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "nodemailer": "^9.0.1",
    "zod": "^4.3.6"
  }
}
