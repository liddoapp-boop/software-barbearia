# App
# Use production em deploy controlado real.
NODE_ENV=development
PORT=3333

# Use DATA_BACKEND=prisma em homologacao/producao controlada.
DATA_BACKEND=memory

# Auth / Security
# Em producao controlada, mantenha AUTH_ENFORCED=true.
AUTH_ENFORCED=true

# Exemplo inseguro para desenvolvimento local. Nunca commitar o valor real.
# Em producao, use valor aleatorio forte com pelo menos 32 caracteres.
AUTH_SECRET=dev-secret-change-me

# Fallback dev/memory. Em producao com DATA_BACKEND=prisma, prefira usuarios persistentes.
# Nao use estas credenciais dev como credenciais reais.
AUTH_USERS_JSON=[{"id":"usr-owner","email":"owner@barbearia.local","password":"owner123","role":"owner","unitIds":["unit-01"]}]

# Database (required when DATA_BACKEND=prisma)
# Exemplo local. Nunca commitar DATABASE_URL real de homologacao/producao.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/barbearia?schema=public"

# Billing/webhooks (configure somente se usar integracoes de billing)
BILLING_WEBHOOK_SECRET=billing-dev-secret
# BILLING_WEBHOOK_SECRET_STRIPE=replace-with-provider-secret
# BILLING_WEBHOOK_SECRET_MERCADO_PAGO=replace-with-provider-secret

# Optional logs
HTTP_LOG_ENABLED=true
LOG_LEVEL=info

# Smoke local/validacao
# Opcional: informe uma API ja iniciada ou uma porta alternativa para o script subir a API atual.
# Exemplo PowerShell:
# $env:SMOKE_BASE_URL="http://127.0.0.1:3334"; npm.cmd run smoke:api
# SMOKE_BASE_URL=http://127.0.0.1:3334

# CORS
# Dev/local pode omitir para manter permissivo. Em homologacao/producao controlada,
# defina a origem real do frontend, ou uma lista separada por virgula.
# CORS_ORIGIN=https://barbearia.example.com
# CORS_ORIGIN=https://barbearia.example.com,https://admin.barbearia.example.com
