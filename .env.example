# App
# Use production em deploy controlado real.
NODE_ENV=development
PORT=3333
# Loopback e o default seguro. Use outro bind apenas com exposicao deliberada e firewall revisado.
HOST=127.0.0.1

# Dev/local pode usar memory. Producao falha no startup se nao for prisma.
DATA_BACKEND=memory

# Unidade usada pelo link publico de agendamento.
PUBLIC_BOOKING_UNIT_ID=unit-01

# Auth / Security
# Em producao controlada, AUTH_ENFORCED=false falha no startup.
AUTH_ENFORCED=true

# Exemplo inseguro para desenvolvimento local. Nunca commitar o valor real.
# Em producao, use valor aleatorio forte com pelo menos 32 caracteres.
# Valores de exemplo/documentacao e segredos curtos sao recusados no startup.
AUTH_SECRET=dev-secret-change-me
# Sessao do painel em cookie HttpOnly; minimo 300 s, maximo 28800 s, default 1800 s.
# Logout/revogacao e rate limit usam memoria no modo local de instancia unica;
# clusters precisam de um store compartilhado antes de escalar horizontalmente.
# AUTH_SESSION_TTL_SEC=1800
# Cabecalhos de proxy so sao aceitos quando esta opcao e habilitada deliberadamente.
# false por padrao; se houver proxy local, liste apenas IPs/CIDRs conhecidos (ex.: 127.0.0.1,::1)
TRUST_PROXY=false

# Limites locais por janela. Em cluster, substitua o contador em memoria por store compartilhado.
# RATE_LIMIT_LOGIN_MAX=10
# RATE_LIMIT_PUBLIC_READ_MAX=60
# RATE_LIMIT_PUBLIC_WRITE_MAX=20
# RATE_LIMIT_AUTHENTICATED_MAX=600
# RATE_LIMIT_REPORTS_MAX=60
# RATE_LIMIT_WHATSAPP_MAX=120
# RATE_LIMIT_AUDIO_MAX=12
# HTTP_BODY_LIMIT_BYTES=1048576

# Fallback somente para desenvolvimento local/memory.
# Em producao, deixe vazio e use usuarios persistentes reais do banco.
# Credenciais dev owner123/recepcao123/profissional123 sao recusadas em producao.
# AUTH_USERS_JSON=[{"id":"usr-owner","email":"owner@barbearia.local","password":"owner123","role":"owner","unitIds":["unit-01"]}]

# Database (required when DATA_BACKEND=prisma)
# Exemplo local. Nunca commitar DATABASE_URL real de homologacao/producao.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/barbearia?schema=public"

# Billing/webhooks (configure somente se usar integracoes de billing)
BILLING_WEBHOOK_SECRET=billing-dev-secret
# BILLING_WEBHOOK_SECRET_STRIPE=replace-with-provider-secret
# BILLING_WEBHOOK_SECRET_MERCADO_PAGO=replace-with-provider-secret

# Optional logs
HTTP_LOG_ENABLED=true
LOG_LEVEL=info

# Smoke local/validacao
# Opcional: informe uma API ja iniciada ou uma porta alternativa para o script subir a API atual.
# Para smoke local em NODE_ENV diferente de production, o runner usa owner@barbearia.local/owner123
# se SMOKE_OWNER_EMAIL e SMOKE_OWNER_PASSWORD nao forem informados.
# Para producao ou SMOKE_BASE_URL remoto, informe credenciais reais do ambiente.
# O runner nunca imprime a senha e retorna erro diagnostico em 401/403 de login.
# Exemplo multiplataforma (Node.js):
# SMOKE_BASE_URL=http://127.0.0.1:3334 npm run smoke:api
# SMOKE_BASE_URL=https://api.example.com SMOKE_OWNER_EMAIL=dono@example.com SMOKE_OWNER_PASSWORD=senha-real npm run smoke:api
# Exemplo PowerShell opcional:
# $env:SMOKE_BASE_URL="http://127.0.0.1:3334"; npm.cmd run smoke:api:ps
# SMOKE_BASE_URL=http://127.0.0.1:3334
# SMOKE_UNIT_ID=unit-01
# SMOKE_OWNER_EMAIL=owner@barbearia.local
# SMOKE_OWNER_PASSWORD=owner123

# CORS
# Dev/local pode omitir para manter permissivo. Em producao, CORS_ORIGIN e obrigatorio,
# nao pode ser "*" e deve conter a origem real do frontend, ou lista separada por virgula.
# CORS_ORIGIN=https://barbearia.example.com
# CORS_ORIGIN=https://barbearia.example.com,https://admin.barbearia.example.com

# Seed/testes DB
# prisma/seed.ts e destrutivo, bloqueado com NODE_ENV=production e permitido apenas
# para dev/test. Bancos nao-locais exigem ALLOW_DESTRUCTIVE_SEED=true com base isolada.
# test:db exige RUN_DB_TESTS=1, DATABASE_URL e recusa URLs com indicios de producao.
# RUN_DB_TESTS=1
# ALLOW_DESTRUCTIVE_SEED=false

# Firebase Auth (opcional; necessario para login via Firebase)
# FIREBASE_PROJECT_ID=liddo-barber
# FIREBASE_USERS_JSON=[{"email":"dono@barbearia.com","role":"owner","unitIds":["unit-01"]}]

# WhatsApp / Evolution API (opcional)
# EVOLUTION_API_URL=https://evolution.example.com
# EVOLUTION_API_KEY=replace-with-real-key
# EVOLUTION_INSTANCE_NAME=liddo-barber
# AI_WHATSAPP_ENABLED=false
# AI_WHATSAPP_OWNER_PHONE=5511999999999
# AI_WHATSAPP_UNIT_ID=unit-01
# AI_WHATSAPP_WEBHOOK_DEDUP_TTL_MS=604800000
# EVOLUTION_WEBHOOK_SECRET=replace-with-local-webhook-secret
# AI_ASSISTANT_PANEL_ENABLED=false

# Email SMTP Gmail (opcional)
# GMAIL_USER=contato@barbearia.com
# GMAIL_APP_PASSWORD=replace-with-gmail-app-password

# Nome usado nas mensagens ao cliente
BARBER_NAME=Barbearia

# Núcleo semântico local (offline)
# O caminho padrão combina interpretação determinística com Gemma local.
# SEMANTIC_PROVIDER=local_llama
# LOCAL_LLAMA_URL=http://127.0.0.1:11435
# REACTIVATION_DEFAULT_RETURN_DAYS=45
# REACTIVATION_COOLDOWN_DAYS=30
# LOCAL_LLAMA_MODEL=google_gemma-3-4b-it-Q4_K_M.gguf
# LOCAL_LLAMA_MODEL_SHA256=4996030242583a40aa151ff93f49ed787ac8c25e4120c3ae4588b2e2a7d1ae94
# LOCAL_LLAMA_TIMEOUT_MS=15000

# Transcricao de audio do atendente WhatsApp (opcional, desativada por padrao)
# O provider mock e aceito somente com NODE_ENV=test; nunca o habilite em producao.
# O canal so e ativado quando as duas flags abaixo estao true e o provider e local_whisper.
# AI_WHATSAPP_AUDIO_ENABLED=false
# AI_AUDIO_TRANSCRIPTION_ENABLED=false
# ASR_PROVIDER=local_whisper
# Compatibilidade legada: AI_AUDIO_TRANSCRIPTION_PROVIDER=gemini
# Caminhos absolutos devem apontar para artefatos locais fora do repositorio.
# LOCAL_WHISPER_FFMPEG_PATH=C:\caminho\isolado\ffmpeg.exe
# LOCAL_WHISPER_CLI_PATH=C:\caminho\isolado\whisper-cli.exe
# LOCAL_WHISPER_MODEL_PATH=C:\caminho\isolado\ggml-large-v3-turbo-q5_0.bin
# LOCAL_WHISPER_VAD_MODEL_PATH=C:\caminho\isolado\ggml-silero-v6.2.0.bin
# LOCAL_WHISPER_GPU_ENABLED=true
# LOCAL_WHISPER_PROMPT=Barbearia. Preserve nomes proprios, servicos, produtos, datas e horarios.
# AI_AUDIO_TRANSCRIPTION_API_KEY=replace-with-real-google-ai-studio-key
# AI_AUDIO_TRANSCRIPTION_MODEL=gemini-3.5-flash
# Timeout operacional da transcricao; o adapter aceita valores entre 5000 e 45000 ms.
# O ASR local usa exatamente 20000 ms, GPU obrigatoria e uma execucao concorrente.
# AI_AUDIO_TRANSCRIPTION_TIMEOUT_MS=20000
# AI_AUDIO_TRANSCRIPTION_TOTAL_BUDGET_MS=45000
# AI_AUDIO_TRANSCRIPTION_MAX_RETRIES=2
# AI_AUDIO_TRANSCRIPTION_MODEL_FALLBACK_ENABLED=false
# AI_AUDIO_TRANSCRIPTION_FALLBACK_MODEL=
# AI_AUDIO_TRANSCRIPTION_CIRCUIT_429_THRESHOLD=2
# AI_AUDIO_TRANSCRIPTION_CIRCUIT_COOLDOWN_MS=60000
# AI_AUDIO_MAX_BYTES=8388608
# AI_AUDIO_MAX_DURATION_SECONDS=120
# AI_AUDIO_MAX_CONCURRENT=2
# AI_WHATSAPP_AUDIO_DOWNLOAD_TIMEOUT_MS=8000
# AI_WHATSAPP_SEND_TIMEOUT_MS=10000

## ---------------------------
## Exemplos / Instruções para VPS (produção)
## Copie as variáveis abaixo para o arquivo `.env` na VPS e preencha os valores reais.
## Nunca comite o arquivo `.env` com segredos.
## ---------------------------
# NODE_ENV=production
# PORT=3333
# DATA_BACKEND=prisma
# PUBLIC_BOOKING_UNIT_ID=unit-01
# AUTH_ENFORCED=true
# AUTH_SECRET=uma-chave-aleatoria-e-segura-com-32-ou-mais-caracteres
# DATABASE_URL="postgresql://barbearia:SUBSTITUA_A_SENHA@127.0.0.1:5432/barbearia?schema=public"
# CORS_ORIGIN=http://IP_DA_SUA_VPS
# HTTP_LOG_ENABLED=true
# LOG_LEVEL=info
# SEED_OWNER_EMAIL=dono@barbearia.com
# SEED_OWNER_PASSWORD=senha-forte-somente-para-seed-inicial
# SEED_OWNER_UNIT_IDS=unit-01,unit-02
