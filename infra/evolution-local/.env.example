# Copy this file to .env and fill local-only secrets.
# Never commit infra/evolution-local/.env.

EVOLUTION_API_PORT=8080
EVOLUTION_MANAGER_PORT=3000
SERVER_URL=http://localhost:8080

AUTHENTICATION_API_KEY=replace_with_a_strong_local_key
EVOLUTION_INSTANCE_NAME=geovane-local

POSTGRES_DATABASE=evolution_local
POSTGRES_USERNAME=evolution_local
POSTGRES_PASSWORD=replace_with_a_strong_local_password
