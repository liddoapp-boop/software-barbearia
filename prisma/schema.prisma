generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_SERVICE
  COMPLETED
  CANCELLED
  NO_SHOW
  BLOCKED
}

enum FinancialKind {
  INCOME
  EXPENSE
}

enum RevenueSource {
  SERVICE
  PRODUCT
  COMMISSION
  REFUND
}

enum StockMovementType {
  IN
  OUT
  LOSS
  INTERNAL_USE
}

enum LoyaltyType {
  POINTS
  CASHBACK
}

enum LoyaltySourceType {
  SERVICE
  PRODUCT
  ADJUSTMENT
  REDEEM
}

enum ClientPackageStatus {
  ACTIVE
  EXPIRED
  DEPLETED
  CANCELLED
}

enum ClientSubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum RetentionCaseStatus {
  OPEN
  IN_PROGRESS
  CONVERTED
  LOST
}

enum RetentionRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum AutomationExecutionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum IntegrationWebhookDirection {
  INBOUND
  OUTBOUND
}

enum IntegrationWebhookStatus {
  SUCCESS
  FAILED
}

model Unit {
  id               String           @id
  name             String
  timezone         String           @default("America/Sao_Paulo")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  businessSettings BusinessSettings?
  businessHours    BusinessHour[]
  paymentMethods   PaymentMethod[]
  businessCommissionRules BusinessCommissionRule[]
  teamMembers      TeamMember[]
  clients          Client[]
  appointments     Appointment[]
  financialEntries FinancialEntry[]
  productSales     ProductSale[]
  refunds          Refund[]
  stockMovements   StockMovement[]
  loyaltyPrograms  LoyaltyProgram[]
  loyaltyLedger    LoyaltyLedger[]
  servicePackages  ServicePackage[]
  clientPackages   ClientPackage[]
  subscriptionPlans SubscriptionPlan[]
  clientSubscriptions ClientSubscription[]
  retentionCases   RetentionCase[]
  automationRules  AutomationRule[]
  automationExecutions AutomationExecution[]
  retentionScoreSnapshots RetentionScoreSnapshot[]
  integrationWebhookLogs IntegrationWebhookLog[]
  billingSubscriptionEvents BillingSubscriptionEvent[]
  serviceStockConsumptions ServiceStockConsumption[]
  monthlyGoals    MonthlyGoal[]
  idempotencyRecords IdempotencyRecord[]
  auditLogs       AuditLog[]
  userAccesses    UserUnitAccess[]
}

model User {
  id            String           @id
  email         String           @unique
  passwordHash  String
  name          String
  role          String
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  unitAccesses  UserUnitAccess[]

  @@index([role, isActive])
}

model UserUnitAccess {
  id        String   @id
  userId    String
  unitId    String
  role      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@unique([userId, unitId])
  @@index([unitId, isActive])
  @@index([userId, isActive])
}

model BusinessSettings {
  id                             String   @id
  unitId                         String   @unique
  businessName                   String
  segment                        String
  phone                          String?
  email                          String?
  address                        String?
  city                           String?
  state                          String?
  document                       String?
  displayName                    String?
  primaryColor                   String?
  themeMode                      String   @default("light")
  defaultAppointmentDuration     Int      @default(45)
  minimumAdvanceMinutes          Int      @default(30)
  bufferBetweenAppointmentsMinutes Int    @default(10)
  reminderLeadMinutes            Int      @default(60)
  sendAppointmentReminders       Boolean  @default(true)
  inactiveCustomerDays           Int      @default(60)
  atRiskCustomerDays             Int      @default(30)
  allowWalkIns                   Boolean  @default(true)
  allowOutOfHoursAppointments    Boolean  @default(false)
  allowOverbooking               Boolean  @default(false)
  houseCommissionType            String   @default("PERCENTAGE")
  houseCommissionValue           Decimal  @db.Decimal(10, 2) @default(40)
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
  unit                           Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)
}

model MonthlyGoal {
  id                   String   @id
  businessId           String
  month                Int
  year                 Int
  revenueTarget        Decimal  @db.Decimal(12, 2)
  appointmentsTarget   Int
  averageTicketTarget  Decimal? @db.Decimal(10, 2)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  business             Unit     @relation(fields: [businessId], references: [id], onDelete: Restrict)

  @@unique([businessId, year, month])
  @@index([businessId, year, month])
}

model BusinessHour {
  id         String   @id
  unitId     String
  dayOfWeek  Int
  opensAt    String?
  closesAt   String?
  breakStart String?
  breakEnd   String?
  isClosed   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  unit       Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@unique([unitId, dayOfWeek])
  @@index([unitId])
}

model PaymentMethod {
  id        String   @id
  unitId    String
  name      String
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([unitId, isActive])
}

model BusinessCommissionRule {
  id             String   @id
  unitId         String
  professionalId String?
  serviceId      String?
  type           String
  value          Decimal  @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  unit           Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  service        Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([unitId, isActive])
  @@index([professionalId])
  @@index([serviceId])
}

model TeamMember {
  id            String   @id
  unitId        String
  name          String
  role          String
  accessProfile String
  email         String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  unit          Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([unitId, isActive])
}

model Service {
  id             String        @id
  businessId     String        @default("unit-01")
  name           String
  description    String?
  category       String?
  price          Decimal       @db.Decimal(10, 2)
  durationMin    Int
  defaultCommissionRate Decimal @db.Decimal(5, 4) @default(0)
  costEstimate   Decimal       @db.Decimal(10, 2)
  notes          String?
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  appointments   Appointment[]
  professionals  ServiceProfessional[]
  stockConsumptions ServiceStockConsumption[]
  businessCommissionRules BusinessCommissionRule[]

  @@index([businessId, active])
  @@index([businessId, category])
}

model Professional {
  id              String           @id
  name            String
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  appointments    Appointment[]
  commissionRules CommissionRule[]
  businessCommissionRules BusinessCommissionRule[]
  commissions     CommissionEntry[]
  productSales    ProductSale[]
  services        ServiceProfessional[]
}

model ServiceProfessional {
  id             String       @id
  serviceId      String
  professionalId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([serviceId, professionalId])
  @@index([professionalId])
}

model CommissionRule {
  id                       String       @id
  professionalId           String
  appliesTo                RevenueSource
  serviceCategory          String?
  percentage               Decimal?     @db.Decimal(8, 4)
  fixedAmount              Decimal?     @db.Decimal(10, 2)
  goalThreshold            Decimal?     @db.Decimal(10, 2)
  extraPercentageAfterGoal Decimal?     @db.Decimal(8, 4)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  professional             Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, appliesTo])
}

model Client {
  id                       String        @id
  businessId               String        @default("unit-01")
  fullName                 String
  phone                    String?
  email                    String?
  birthDate                DateTime?
  notes                    String?
  preferredProfessionalId  String?
  tags                     String[]
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  business                 Unit          @relation(fields: [businessId], references: [id], onDelete: Restrict)
  appointments             Appointment[]
  productSales             ProductSale[]
  loyaltyLedger            LoyaltyLedger[]
  clientPackages           ClientPackage[]
  clientSubscriptions      ClientSubscription[]
  retentionCases           RetentionCase[]
  automationExecutions     AutomationExecution[]
  retentionScoreSnapshots  RetentionScoreSnapshot[]

  @@index([businessId, fullName])
  @@index([businessId, phone])
}

model Product {
  id               String          @id
  businessId       String          @default("unit-01")
  name             String
  category         String
  salePrice        Decimal         @db.Decimal(10, 2)
  costPrice        Decimal         @db.Decimal(10, 2)
  stockQty         Int             @default(0)
  minStockAlert    Int             @default(0)
  notes            String?
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  productSaleItems ProductSaleItem[]
  stockMovements   StockMovement[]
  refundItems      RefundItem[]
  serviceConsumptions ServiceStockConsumption[]

  @@index([businessId, active])
}

model ServiceStockConsumption {
  id                 String   @id
  unitId             String
  serviceId          String
  productId          String
  quantityPerService Decimal  @db.Decimal(10, 3)
  wastePct           Decimal  @db.Decimal(5, 2) @default(0)
  isCritical         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  unit               Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)
  service            Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  product            Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([unitId, serviceId, productId])
  @@index([unitId, serviceId])
  @@index([productId])
}

model Appointment {
  id             String                @id
  unitId         String
  clientId       String
  professionalId String
  serviceId      String
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus
  isFitting      Boolean               @default(false)
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  unit           Unit                  @relation(fields: [unitId], references: [id], onDelete: Restrict)
  client         Client                @relation(fields: [clientId], references: [id], onDelete: Restrict)
  professional   Professional          @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  service        Service               @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  history        AppointmentHistory[]
  commissions    CommissionEntry[]
  refunds        Refund[]

  @@index([unitId, startsAt])
  @@index([professionalId, startsAt])
  @@index([clientId, startsAt])
}

model AppointmentHistory {
  id            String      @id
  appointmentId String
  changedAt     DateTime
  changedBy     String
  action        String
  reason        String?
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, changedAt])
}

model FinancialEntry {
  id            String        @id
  unitId        String
  kind          FinancialKind
  source        RevenueSource?
  category      String?
  paymentMethod String?
  amount        Decimal       @db.Decimal(10, 2)
  occurredAt    DateTime
  referenceType String
  referenceId   String?
  professionalId String?
  customerId    String?
  description   String
  notes         String?
  idempotencyKey String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  unit          Unit          @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@unique([unitId, idempotencyKey])
  @@unique([unitId, referenceType, referenceId, source])
  @@index([unitId, occurredAt])
}

model CommissionEntry {
  id               String        @id
  professionalId   String
  unitId           String
  appointmentId    String?
  productSaleId    String?
  source           RevenueSource
  baseAmount       Decimal       @db.Decimal(10, 2)
  commissionRate   Decimal?      @db.Decimal(8, 4)
  commissionAmount Decimal       @db.Decimal(10, 2)
  status           String        @default("PENDING")
  occurredAt       DateTime
  ruleId           String
  idempotencyKey   String?
  createdAt        DateTime      @default(now())
  paidAt           DateTime?
  professional     Professional  @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  appointment      Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  productSale      ProductSale?  @relation(fields: [productSaleId], references: [id], onDelete: SetNull)

  @@unique([unitId, idempotencyKey])
  @@unique([unitId, source, appointmentId])
  @@unique([unitId, source, productSaleId])
  @@index([professionalId, occurredAt])
  @@index([unitId, occurredAt])
}

model ProductSale {
  id             String            @id
  unitId         String
  clientId       String?
  professionalId String?
  grossAmount    Decimal           @db.Decimal(10, 2)
  soldAt         DateTime
  idempotencyKey String?
  createdAt      DateTime          @default(now())
  unit           Unit              @relation(fields: [unitId], references: [id], onDelete: Restrict)
  client         Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  professional   Professional?     @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  items          ProductSaleItem[]
  commissions    CommissionEntry[]
  refunds        Refund[]

  @@unique([unitId, idempotencyKey])
  @@index([unitId, soldAt])
}

model ProductSaleItem {
  id           String      @id
  productSaleId String
  productId    String
  quantity     Int
  unitPrice    Decimal     @db.Decimal(10, 2)
  unitCost     Decimal     @db.Decimal(10, 2)
  productSale  ProductSale @relation(fields: [productSaleId], references: [id], onDelete: Cascade)
  product      Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([productSaleId])
  @@index([productId])
}

model Refund {
  id             String   @id
  unitId         String
  appointmentId  String?
  productSaleId  String?
  totalAmount    Decimal  @db.Decimal(10, 2)
  reason         String
  refundedAt     DateTime
  changedBy      String
  idempotencyKey String?
  createdAt      DateTime @default(now())
  unit           Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)
  appointment    Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  productSale    ProductSale? @relation(fields: [productSaleId], references: [id], onDelete: SetNull)
  items          RefundItem[]

  @@unique([unitId, idempotencyKey])
  @@unique([unitId, appointmentId])
  @@index([unitId, refundedAt])
  @@index([appointmentId])
  @@index([productSaleId])
}

model RefundItem {
  id        String  @id
  refundId  String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  amount    Decimal @db.Decimal(10, 2)
  refund    Refund  @relation(fields: [refundId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([refundId])
  @@index([productId])
}

model StockMovement {
  id            String            @id
  unitId        String
  productId     String
  movementType  StockMovementType
  quantity      Int
  occurredAt    DateTime
  referenceType String
  referenceId   String?
  createdAt     DateTime          @default(now())
  unit          Unit              @relation(fields: [unitId], references: [id], onDelete: Restrict)
  product       Product           @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([unitId, productId, referenceType, referenceId, movementType])
  @@index([unitId, occurredAt])
  @@index([productId, occurredAt])
}

model IdempotencyRecord {
  id             String   @id
  unitId         String
  action         String
  idempotencyKey String
  payloadHash    String
  status         String
  responseJson   Json?
  resolution     String?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  unit           Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@unique([unitId, action, idempotencyKey])
  @@index([unitId, action, status, createdAt])
  @@index([expiresAt])
}

model AuditLog {
  id             String   @id
  unitId         String
  actorId        String
  actorEmail     String?
  actorRole      String
  action         String
  entity         String
  entityId       String?
  route          String
  method         String
  requestId      String
  idempotencyKey String?
  beforeJson     Json?
  afterJson      Json?
  metadataJson   Json?
  createdAt      DateTime @default(now())
  unit           Unit     @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([unitId, createdAt])
  @@index([unitId, entity, createdAt])
  @@index([unitId, action, createdAt])
  @@index([unitId, actorId, createdAt])
  @@index([requestId])
  @@index([idempotencyKey])
}

model LoyaltyProgram {
  id             String       @id
  unitId         String
  name           String
  type           LoyaltyType
  conversionRate Decimal      @db.Decimal(10, 4)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  unit           Unit         @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([unitId, isActive])
}

model LoyaltyLedger {
  id           String            @id
  unitId       String
  clientId     String
  sourceType   LoyaltySourceType
  sourceId     String?
  pointsDelta  Decimal           @db.Decimal(10, 2)
  balanceAfter Decimal           @db.Decimal(10, 2)
  occurredAt   DateTime
  createdBy    String
  createdAt    DateTime          @default(now())
  unit         Unit              @relation(fields: [unitId], references: [id], onDelete: Restrict)
  client       Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@index([unitId, clientId, occurredAt])
}

model ServicePackage {
  id                String          @id
  unitId            String
  name              String
  price             Decimal         @db.Decimal(10, 2)
  sessionsTotal     Int
  sessionsByService Json?
  validityDays      Int
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  unit              Unit            @relation(fields: [unitId], references: [id], onDelete: Restrict)
  clientPackages    ClientPackage[]

  @@index([unitId, isActive])
}

model ClientPackage {
  id                String             @id
  unitId            String
  clientId          String
  packageId         String
  purchasedAt       DateTime
  expiresAt         DateTime
  sessionsRemaining Int
  status            ClientPackageStatus
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  unit              Unit               @relation(fields: [unitId], references: [id], onDelete: Restrict)
  client            Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  package           ServicePackage     @relation(fields: [packageId], references: [id], onDelete: Restrict)

  @@index([unitId, clientId, status])
}

model SubscriptionPlan {
  id              String               @id
  unitId          String
  name            String
  priceMonthly    Decimal              @db.Decimal(10, 2)
  billingDay      Int
  benefits        Json?
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  unit            Unit                 @relation(fields: [unitId], references: [id], onDelete: Restrict)
  subscriptions   ClientSubscription[]

  @@index([unitId, isActive])
}

model ClientSubscription {
  id            String                   @id
  unitId        String
  clientId      String
  planId        String
  startedAt     DateTime
  nextBillingAt DateTime
  status        ClientSubscriptionStatus
  cycleCount    Int                      @default(1)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  unit          Unit                     @relation(fields: [unitId], references: [id], onDelete: Restrict)
  client        Client                   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  plan          SubscriptionPlan         @relation(fields: [planId], references: [id], onDelete: Restrict)
  billingEvents BillingSubscriptionEvent[]

  @@index([unitId, clientId, status])
}

model RetentionCase {
  id                String             @id
  unitId            String
  clientId          String
  status            RetentionCaseStatus
  riskLevel         RetentionRiskLevel
  reason            String
  recommendedAction String
  lastVisitAt       DateTime?
  daysWithoutReturn Int                @default(0)
  ownerUser         String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  unit              Unit               @relation(fields: [unitId], references: [id], onDelete: Restrict)
  client            Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  events            RetentionEvent[]

  @@index([unitId, status, riskLevel])
}

model RetentionEvent {
  id         String         @id
  caseId     String
  channel    String
  note       String
  outcome    String?
  occurredAt DateTime
  createdBy  String
  createdAt  DateTime       @default(now())
  retentionCase RetentionCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, occurredAt])
}

model AutomationRule {
  id              String               @id
  unitId          String
  name            String
  triggerType     String
  channel         String
  target          String
  messageTemplate String
  isActive        Boolean              @default(true)
  createdBy       String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  unit            Unit                 @relation(fields: [unitId], references: [id], onDelete: Restrict)
  executions      AutomationExecution[]

  @@index([unitId, isActive])
}

model AutomationExecution {
  id             String                    @id
  unitId         String
  ruleId         String?
  clientId       String?
  campaignType   String
  status         AutomationExecutionStatus
  attempts       Int                       @default(1)
  idempotencyKey String
  errorMessage   String?
  payload        Json?
  startedAt      DateTime
  finishedAt     DateTime?
  unit           Unit                      @relation(fields: [unitId], references: [id], onDelete: Restrict)
  rule           AutomationRule?           @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  client         Client?                   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@unique([unitId, idempotencyKey])
  @@index([unitId, status, startedAt])
}

model RetentionScoreSnapshot {
  id                String            @id
  unitId            String
  clientId          String
  riskScore         Decimal           @db.Decimal(5, 2)
  riskLevel         RetentionRiskLevel
  returnProbability Decimal           @db.Decimal(5, 2)
  reasons           Json
  modelVersion      String
  scoredAt          DateTime
  createdAt         DateTime          @default(now())
  unit              Unit              @relation(fields: [unitId], references: [id], onDelete: Restrict)
  client            Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@index([unitId, scoredAt])
  @@index([unitId, riskLevel, scoredAt])
}

model IntegrationWebhookLog {
  id            String                    @id
  unitId        String
  provider      String
  direction     IntegrationWebhookDirection
  endpoint      String
  status        IntegrationWebhookStatus
  httpStatus    Int?
  attempt       Int                       @default(1)
  correlationId String
  payload       Json?
  responseBody  Json?
  errorMessage  String?
  occurredAt    DateTime
  createdAt     DateTime                  @default(now())
  unit          Unit                      @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([unitId, provider, status, occurredAt])
}

model BillingSubscriptionEvent {
  id                     String             @id
  unitId                 String
  subscriptionId         String?
  externalSubscriptionId String?
  eventType              String
  amount                 Decimal?           @db.Decimal(10, 2)
  status                 String
  occurredAt             DateTime
  payload                Json?
  createdAt              DateTime           @default(now())
  unit                   Unit               @relation(fields: [unitId], references: [id], onDelete: Restrict)
  subscription           ClientSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([unitId, status, occurredAt])
  @@index([subscriptionId, occurredAt])
}
